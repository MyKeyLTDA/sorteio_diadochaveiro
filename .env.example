# ===== Variaveis de ambiente — configure no Netlify (Site settings > Environment variables) =====
# NUNCA suba este arquivo preenchido para o GitHub.

# --- Supabase (pegue em Project Settings > API) ---
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_key_aqui   # SECRETA. Nunca vai pro navegador.

# --- Senha do painel de admin (/admin.html) ---
ADMIN_PASSWORD=escolha_uma_senha_forte

# --- Segredo para o hash do codigo OTP (string aleatoria longa) ---
OTP_SECRET=gere_uma_string_aleatoria_longa_aqui

# --- SMTP do seu proprio dominio ---
SMTP_HOST=mail.seudominio.com.br
SMTP_PORT=587
SMTP_SECURE=false                 # true se usar porta 465
SMTP_USER=sorteio@seudominio.com.br
SMTP_PASS=senha_do_email
SMTP_FROM=MyKey Sorteio <sorteio@seudominio.com.br>
